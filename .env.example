# ═══════════════════════════════════════════════════════════════════════
# ZARA OS — Environment Variables (Template)
# Copy to .env.local and fill in. NEVER commit .env or .env.local.
# ═══════════════════════════════════════════════════════════════════════

# ─── App ───
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=zara-os
LOG_LEVEL=info

# ─── Database (Supabase HIPAA tier when provisioned) ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zara_os_dev
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Auth ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ─── FHIR Server (Medplum fork) ───
FHIR_BASE_URL=http://localhost:8103/fhir/R4
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=

# ─── AWS (when cloud provisioned) ───
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_KEY_ID=
AWS_S3_BUCKET_PHI=
AWS_S3_BUCKET_AUDIT=

# ─── Bedrock (AI inference) ───
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_OPUS=anthropic.claude-opus-4-1-20250805-v1:0
BEDROCK_MODEL_SONNET=anthropic.claude-sonnet-4-5-20250929-v1:0

# ─── Transcribe Medical ───
TRANSCRIBE_REGION=us-east-1
TRANSCRIBE_VOCABULARY_NAME=

# ─── Cloudflare (edge, non-PHI) ───
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─── Stripe ───
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CORE=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# ─── Twilio (voice + SMS) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Monitoring ───
SENTRY_DSN=
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ─── Feature flags ───
FEATURE_AGENT_P_ENABLED=true
FEATURE_AGENT_A_ENABLED=true
FEATURE_AGENT_Z_ENABLED=true
FEATURE_AGENT_R_ENABLED=false
FEATURE_AGENT_M_ENABLED=false
FEATURE_BREAK_GLASS_ENABLED=true

# ─── Compliance ───
HIPAA_AUDIT_RETENTION_DAYS=2555
PHI_ENCRYPTION_KEY_ROTATION_DAYS=90
SESSION_TIMEOUT_MINUTES=15
MFA_REQUIRED=true
