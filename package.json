{
  "name": "zara-os",
  "version": "0.0.1",
  "private": true,
  "description": "Zara OS — AI-native operating system for hospitals and independent practices",
  "author": "Dr. Jessica Edwards, DO MBA <jessica@zaramedical.com>",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:probes": "turbo run test:probes",
    "test:fhir": "turbo run test:fhir-conformance",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky",
    "audit:security": "pnpm audit --audit-level=critical",
    "audit:hipaa": "node scripts/hipaa-control-check.mjs",
    "watchdog": "node scripts/hallucination-watchdog.mjs"
  },
  "devDependencies": {
    "turbo": "2.3.3",
    "typescript": "5.8.3",
    "@types/node": "22.10.2",
    "prettier": "3.4.2",
    "husky": "9.1.7",
    "lint-staged": "15.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["prettier --write"],
    "*.py": ["ruff format", "ruff check --fix"]
  }
}
